


# LAYOUT #

# binary report file with #
-- report id       ( int )
-- Inspector name  ( fixed length string, provided by --user argument )
-- GPS coordinates ( latitude and longitude as float )
-- Issue category  ( fixed string : "road","lightning","flooding"" )
-- Severity level  ( int : 1,2,3 minor,moderate,critical )
-- Timestamp       ( time_t )
-- Description     ( fixed string )
-- district.cfg    ( text config -severity threshold )
-- logged_district ( operation log text, every action performed on district with timestamp declared role declared user name )
